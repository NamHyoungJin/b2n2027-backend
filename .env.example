DJANGO_SECRET_KEY=replace-with-a-secure-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_BEHIND_HTTPS_PROXY=False
DJANGO_USE_X_FORWARDED_HOST=False

# DEBUG=False 일 때도 로컬 디스크 MEDIA(/media/)를 Django가 서빙하게 함(S3만 쓰고 nginx가 /media/ 담당이면 불필요).
# DJANGO_SERVE_LOCAL_MEDIA=1

# 이미지 키→URL 직렬화 시 request 컨텍스트가 없을 때 붙일 절대 Origin(기본 localhost:8000).
# 상대 경로 /media/... 만 내려가면 관리자·다른 포트에서 img 요청이 프론트로 가 404가 납니다.
# DJANGO_PUBLIC_ORIGIN=http://localhost:8000

# MySQL — Django는 TCP로 접속합니다. root가 비번 없이 socket 전용(1698 Access denied)이면
# 전용 계정을 만드는 것을 권장: CREATE DATABASE b2n2027; CREATE USER 'b2n'@'localhost' IDENTIFIED BY '...';
# GRANT ALL PRIVILEGES ON b2n2027.* TO 'b2n'@'localhost'; FLUSH PRIVILEGES;
DB_NAME=b2n2027
DB_USER=b2n
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=3306
# MySQL 3159 (require_secure_transport=ON): TLS 필수일 때 아래를 켜고, 필요하면 CA 번들 경로 지정
# (예: AWS RDS → rds-combined-ca-bundle.pem 다운로드 후 절대 경로)
DB_SSL_REQUIRED=false
# DB_SSL_CA=/absolute/path/to/ca-bundle.pem

CORS_ALLOWED_ORIGINS=http://localhost:3000,https://www.b2n2027.org

JWT_SECRET_KEY=replace-with-a-secure-random-secret
ADMIN_JWT_REFRESH_COOKIE_NAME=adminRefreshToken
ADMIN_JWT_REFRESH_COOKIE_DOMAIN=
ADMIN_JWT_REFRESH_COOKIE_SAMESITE=Lax
ADMIN_JWT_REFRESH_COOKIE_SECURE=

DEFAULT_FROM_EMAIL=
SPONSOR_INQUIRY_TO=admin_kr@b2n2027.org
GMAIL_SENDER=
GMAIL_APP_PASSWORD=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# 버킷명 — 아래 둘 중 하나만 있어도 됨(settings 에서 AWS_STORAGE_BUCKET_NAME 로 폴백)
AWS_S3_BUCKET_NAME=
# AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION=ap-northeast-2
# AWS_S3_REGION_NAME=  (별칭, settings 에서 AWS_S3_REGION 으로 읽음)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_PRESIGNED_GET_EXPIRES=604800
# www/관리자에서 이미지가 보이게: API가 Presigned 대신 공개 S3 HTTPS URL을 내림. 버킷에 익명 GetObject 허용 정책 필요.
# AWS_S3_PUBLIC_GET_FOR_MANAGED=1
# 공개 URL이 403(버킷 Block Public Access 등)이면 썸네일이 깨짐 → 아래로 Presigned만 쓰거나 PUBLIC 을 끄세요.
# AWS_S3_FORCE_PRESIGNED_FOR_MANAGED=1
# 업로드 시 public-read ACL 시도(Object Ownership 이 ACL 비허용이면 자동으로 ACL 없이 업로드 후 정책으로 공개).
# AWS_S3_UPLOAD_ACL_PUBLIC_READ=1

ALIGO_API_KEY=
ALIGO_USER_ID=
GOOGLE_API_KEY=

B2N_ADMIN_INIT_PASSWORD=ChangeMe1234!
